#!/usr/bin/env bash
set -Eeo pipefail
shopt -s globstar
. bootstrap.sh

function version() {
  export BRANCH=${GITHUB_REF_NAME-$(git rev-parse --abbrev-ref HEAD)}
  export BUILD_NUMBER=${GITHUB_RUN_NUMBER-$(date -u +"%Y%m%d%H%M%S")}
  export REVISIONS=$(git rev-list --count ${BRANCH})
  export VERSION=0.${REVISIONS}.${BUILD_NUMBER}

  echo version: ${VERSION}
}

function clean() {
  rm -rf artifacts
  bun install > /dev/null 2>&1
}

function check() {
  bun run --bun tsgo --noEmit
}

function complexity() {
  bunx oxlint -c .oxlintrc.json ./src/
}

function test() {
  bun test "$@"
}

function dev() {
  test --watch
}

function copy-wasiglk() {
  local src="./node_modules/@bodar/wasiglk/wasm"
  local dest="./www/wasiglk"
  mkdir -p "${dest}"
  cp "${src}"/*.wasm "${dest}/"
  # agt2agx is a server-side converter, not a player interpreter: keep it out of
  # the client assets and place it next to the worker root for a clean bundled
  # import (the CompiledWasm rule picks it up). This is the one node_modules
  # reference, same pattern as bundle-worker above.
  rm -f "${dest}/agt2agx.wasm"
  cp "${src}/agt2agx.wasm" ./src/cloudflare/agt2agx.wasm
}

function bundle-worker() {
  bun build ./node_modules/@bodar/wasiglk/src/worker/worker.ts \
    --outfile ./www/wasiglk/worker.js \
    --target browser --format esm --minify
}

function build-client() {
  copy-wasiglk
  bundle-worker
  local option=${1}
  local src="./src"
  local dest="./www"
  local folders=("player" "cards" "catalogue")

  local bun_prefix=""
  local bg_suffix=""

  if [[ "${option}" == "--watch" ]]; then
    bun_prefix="--watch"
    bg_suffix="&"
  fi

  local ts_files=()
  local css_commands=()

  for folder in "${folders[@]}"; do
    ts_files+=("${src}/${folder}/main.ts")

    local watch_prefix=""
    if [[ "${option}" == "--watch" ]]; then
      watch_prefix="watchexec --exts css -w ${src}/${folder}/"
    fi
    css_commands+=("${watch_prefix} bunx lightningcss --minify --bundle ${src}/${folder}/main.css --output-dir ${dest}/${folder}/")
  done

  eval "bun build ${bun_prefix} --minify ${ts_files[*]} --outdir ${dest}/ ${bg_suffix}"

  for cmd in "${css_commands[@]}"; do
    eval "$cmd $bg_suffix"
  done
}

function build() {
  check
  complexity
  build-client "$@"
  test "$@"
}

function start() {
  check
  build-client --watch
  bun run --watch src/bun/app.ts
}

function start-dynamic() {
  check
  build-client
  PORT=0 bun run src/bun/app.ts
}

function startw() {
  check
  build-client
  bunx wrangler dev --port 3000
}

function tail() {
  bunx wrangler tail
}

function check-rclone() {
    : "${RCLONE_CONFIG_CLOUDFLARE_ACCESS_KEY_ID?Required}"
    : "${RCLONE_CONFIG_CLOUDFLARE_SECRET_ACCESS_KEY?Required}"
    : "${RCLONE_CONFIG_CLOUDFLARE_ENDPOINT?Required}"
}

function deploy() {
  check
  # `wrangler deploy` bundles www/ as Workers Static Assets ([assets] in
  # wrangler.toml), versioned atomically with the Worker. The old rclone push
  # of www/ → R2 is gone; R2 now holds only runtime-written content. rclone is
  # still used by pull/purge for syncing that content locally.
  bunx wrangler deploy
}

function pull() {
  check-rclone
  rm -rf www/content www/cards/art
  rclone --config rclone.conf copy cloudflare:talebrary/content www/content/ --metadata -v
  rclone --config rclone.conf copy cloudflare:talebrary/cards/art www/cards/art --metadata -v
}

function purge() {
  check-rclone
  local target="${1:?Usage: ./run purge <suggestions|art|cover-art|cover-art-original>}"
  echo "Purging cached ${target} from R2..."
  rclone --config rclone.conf delete cloudflare:talebrary/content --include "**/${target}" --include "**/${target}/**" -v
}

function db-sync() {
    ./db/run pipeline
}

function db-download() {
    ./db/run download
}

function db-migrate() {
    ./db/run migrate
}

function evals() {
  bun run evals/run-evals.ts "$@"
}

function evals-ui() {
  bun run evals/serve-evals.ts
}

function ci() {
  build --coverage
  deploy
}

clean

command="${1-build}"
set +e; shift; set -Eeo pipefail;
$command "$@"
