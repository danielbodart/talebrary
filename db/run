#!/usr/bin/env bash
set -Eeo pipefail

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

function mariadb() {
  docker run --detach --name ifarchive --env MARIADB_USER=ifarchive --env MARIADB_PASSWORD=password \
    --env MARIADB_DATABASE=ifarchive --env MARIADB_RANDOM_ROOT_PASSWORD=1 -p 3306:3306 mariadb:10.5.15
}

function download() {
    # IFDB publishes quarterly dumps (ifdb-archive-YYYYMMDD.zip) at an irregular
    # cadence. Rather than guess the date, list the directory and take the
    # lexically-newest file. (Runs in CI, which is not geo-blocked by ifarchive.)
    local base="https://ifarchive.org/if-archive/info/ifdb"
    echo "Finding latest IFDB dump in $base/ ..."
    local latest=$(curl -fsSL "$base/" | grep -oE 'ifdb-archive-[0-9]{8}\.zip' | sort -u | tail -1)
    if [ -z "$latest" ]; then
        echo "ERROR: no ifdb-archive-*.zip found at $base/" >&2
        exit 1
    fi
    echo "Latest dump: $latest"
    curl -f -o "$SCRIPT_DIR/ifdb-latest.zip" "$base/$latest"

    unzip -o "$SCRIPT_DIR/ifdb-latest.zip" -d "$SCRIPT_DIR/"
    # The ZIP contains a single .sql file
    mv "$SCRIPT_DIR"/ifdb-archive-*.sql "$SCRIPT_DIR/ifdb-archive.sql"
    rm "$SCRIPT_DIR/ifdb-latest.zip"
}

function convert-ifdb() {
    pushd "$SCRIPT_DIR"
    echo "Converting IFDB MySQL dump to SQLite..."
    rm -f ifdb.sqlite full-ifdb.sql
    ./mysql2sqlite ifdb-archive.sql > full-ifdb.sql
    sqlite3 ifdb.sqlite < full-ifdb.sql
    echo "IFDB SQLite created: $(sqlite3 ifdb.sqlite 'SELECT COUNT(*) FROM games;') games"
    popd
}

function sync() {
    pushd "$SCRIPT_DIR"
    echo "Syncing IFDB → talebrary..."

    # Ensure talebrary schema exists
    sqlite3 talebrary.sqlite < schema/talebrary.sql

    # Attach IFDB and run sync
    sqlite3 talebrary.sqlite <<EOF
ATTACH DATABASE 'ifdb.sqlite' AS ifdb;
.read sync.sql
DETACH DATABASE ifdb;
.read corrections.sql
EOF

    local total=$(sqlite3 talebrary.sqlite "SELECT COUNT(*) FROM talebrary_games;")
    local enabled=$(sqlite3 talebrary.sqlite "SELECT COUNT(*) FROM talebrary_games WHERE enabled = 1;")
    local links=$(sqlite3 talebrary.sqlite "SELECT COUNT(*) FROM talebrary_gamelinks;")
    echo "Sync complete: $total games ($enabled enabled), $links links"
    popd
}

function upload() {
    local dir="$SCRIPT_DIR"
    . "$SCRIPT_DIR/../bootstrap.sh"   # sourcing bootstrap resets SCRIPT_DIR to repo root
    SCRIPT_DIR="$dir"
    pushd "$SCRIPT_DIR"

    # Safety net: capture a time-travel restore point before writing. If anything
    # looks wrong afterwards: wrangler d1 time-travel restore talebrary --remote --bookmark=<b>
    echo "== D1 time-travel bookmark (rollback point) =="
    bunx wrangler d1 time-travel info talebrary || true

    # Generate the atomic refresh: UPSERT games (preserves curation + incoming FKs),
    # full-replace gamelinks/search, auth tables untouched. See db/gen-upload.ts.
    echo "Generating upload SQL..."
    DB_PATH="$SCRIPT_DIR/talebrary.sqlite" bun run "$SCRIPT_DIR/gen-upload.ts" > d1.sql

    echo "Uploading to D1 (single atomic transaction)..."
    bunx wrangler d1 execute talebrary --remote --file="$SCRIPT_DIR/d1.sql"
    echo "D1 upload complete."
    echo "Games removed from IFDB are NOT auto-disabled — review with: ./db/run prune"
    popd
}

# Report (and optionally soft-disable) games that exist in prod but are absent
# from the latest local build — i.e. removed from IFDB. Never hard-deletes, so
# user data (e.g. favourites) referencing a game is never broken.
#   ./db/run prune            # report only
#   ./db/run prune --disable  # set enabled=0 on stale games
function prune() {
    local dir="$SCRIPT_DIR"
    . "$SCRIPT_DIR/../bootstrap.sh"   # sourcing bootstrap resets SCRIPT_DIR to repo root
    SCRIPT_DIR="$dir"
    pushd "$SCRIPT_DIR"
    bunx wrangler d1 execute talebrary --remote --json \
        --command "SELECT id, enabled FROM talebrary_games" > prod_games.json
    DB_PATH="$SCRIPT_DIR/talebrary.sqlite" bun run "$SCRIPT_DIR/prune.ts" prod_games.json "$@"
    if [[ "$*" == *--disable* && -f prune.sql ]]; then
        echo "Applying prune.sql..."
        bunx wrangler d1 execute talebrary --remote --file="$SCRIPT_DIR/prune.sql"
    fi
    rm -f prod_games.json prune.sql
    popd
}

function migrate() {
    bun run "$SCRIPT_DIR/migrate-run.ts"
}

function pipeline() {
    download
    convert-ifdb
    sync
    upload
}

# Legacy convert (pre-migration)
function convert() {
  pushd "$SCRIPT_DIR"
  rm -f talebrary.sqlite full.sql d1.sql
  ./mysql2sqlite ifdb-archive.sql > full.sql
  cat full.sql | sqlite3 talebrary.sqlite
  sqlite3 talebrary.sqlite .dump > d1.sql
  sed -i '/^BEGIN TRANSACTION;$/d; /^COMMIT;$/d' d1.sql
  popd
}

command="${1-convert}"
set +e; shift; set -Eeo pipefail;
$command "$@"
