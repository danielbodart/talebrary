#!/usr/bin/env bash
set -Eeo pipefail

function run-mariadb() {
  docker run --detach --name ifarchive --env MARIADB_USER=ifarchive --env MARIADB_PASSWORD=password \
    --env MARIADB_DATABASE=ifarchive --env MARIADB_RANDOM_ROOT_PASSWORD=1 -p 3306:3306 mariadb:10.5.15
}

function convert-to-sqlite() {
  rm -f talebrary.sqlite full.sql d1.sql
  ./mysql2sqlite ifdb-archive.sql > full.sql
  cat full.sql | sqlite3 talebrary.sqlite
  cat drop.sql | sqlite3 talebrary.sqlite
  sqlite3 talebrary.sqlite .dump > d1.sql
  sed -i '/^BEGIN TRANSACTION;$/d; /^COMMIT;$/d' d1.sql
  rm -f talebrary.sqlite full.sql
}


command="${1-convert-to-sqlite}"
set +e; shift; set -Eeo pipefail;
$command "$@"

